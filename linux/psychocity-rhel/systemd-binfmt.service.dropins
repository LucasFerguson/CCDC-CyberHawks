[Service]
TimeoutStopFailureMode=abort # src file: /usr/lib/systemd/system/service.d/10-timeout-abort.conf
Environment=SYSTEMD_SLEEP_FREEZE_USER_SESSIONS=0 # src file: /usr/lib/systemd/system/service.d/50-keep-warm.conf
ExecStop= # src file: /run/systemd/generator/systemd-binfmt.service.d/override.conf
ExecStart=/bin/sh -c '(echo -1 > /proc/sys/fs/binfmt_misc/WSLInterop) ; (echo ":WSLInterop:M::MZ::/init:P" > /proc/sys/fs/binfmt_misc/register)' # src file: /run/systemd/generator/systemd-binfmt.service.d/override.conf